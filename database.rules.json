{
  "rules": {
    "players": {
      ".read": true,
      ".indexOn": ["wins", "bestStreak"],
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren()",
        "name":       { ".validate": "newData.isString() && newData.val().length <= 60" },
        "photo":      { ".validate": "newData.isString() && newData.val().length <= 500" },
        "wins":       { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "losses":     { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "games":      { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "accSum":     { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "accCount":   { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "bestStreak": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "updated":    { ".validate": "newData.isNumber()" },
        "$other":     { ".validate": false }
      }
    },
    "queue": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "playerMatch": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    },
    "matches": {
      "$mid": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "parties": {
      "$code": {
        ".read": true,
        ".write": true
      }
    }
  }
}
